{
  "name": "ecommerce-eurostar-api",
  "version": "1.0.0",
  "description": "REST API for an e-commerce demo with JWT auth and checkout (Eurostar conference).",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test:path": "mocha test/pathCoverage/**/*.test.js --require test/pathCoverage/setup.js --reporter mochawesome --reporter-options reportDir=mochawesome-report,reportFilename=path-coverage"
  },
  "keywords": [
    "express",
    "jwt",
    "ecommerce",
    "rest-api"
  ],
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "chai": "^4.5.0",
    "mocha": "^11.7.6",
    "mochawesome": "^7.1.4",
    "supertest": "^7.2.2"
  }
}
